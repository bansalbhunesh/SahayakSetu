# ── Sahayak Environment Variables ──────────────────
# Copy this file to .env and fill in your actual keys

# Qdrant Cloud (https://cloud.qdrant.io — Free tier available)
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Vapi (https://dashboard.vapi.ai — Use code "vapixhackblr" for $30 free credits)
VAPI_API_KEY=your_vapi_private_api_key_here
VAPI_PUBLIC_KEY=your_vapi_public_key_here

# Optional
CHAT_MODEL=gpt-4o-mini
BACKEND_URL=https://your-backend-url.com
