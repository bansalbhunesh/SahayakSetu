# SahayakSetu Environment Template (Audit v3 Compliant)

# Primary Logic Engine (Google AI Studio)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_key_here

# Fallback Intelligence & Concurrency (Groq Cloud)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here

# Vector Infrastructure (Qdrant Cloud/Local)
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Project Orchestration
BACKEND_URL=https://your-backend-url.onrender.com
VAPI_API_KEY=your_vapi_key_here # Optional: For voice orchestration
VAPI_PUBLIC_KEY=your_vapi_public_key_here
